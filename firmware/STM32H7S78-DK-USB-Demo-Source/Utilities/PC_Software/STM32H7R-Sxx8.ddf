
;; Architecture extensions
;;#include weak "..\ARM\ARMv7-M-MPU.ddf"
;;#include weak "..\ARM\ARMv7-M-CACHE.ddf"
;;#include weak "..\ARM\CoreSight-ETM-M7.ddf"

;; Memory information ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
;; 
;; Used to define address zones within the ARM address space (Memory). 
;;
;;   Name      may be almost anything
;;   AdrSpace  must be Memory
;;   StartAdr  start of memory block
;;   EndAdr    end of memory block
;;   AccType   type of access, read-only (R), read-write (RW) or SFR (W)

[Memory]
;;         Name             AdrSpace    StartAdr    EndAdr      AccType   Width
Memory =  ITCM-RAM         Memory      0x00000000  0x0002FFFF  RW
Memory =  SysMem           Memory      0x1FF00000  0x1FF1FFFF  R
Memory =  DTCM-RAM         Memory      0x20000000  0x2001FFFF  RW 
Memory =  GFXMMU-RAM       Memory      0x25000000  0x25FFFFFF  RW 
Memory =  BackupRAM        Memory      0x38800000  0x38800FFF  RW 
Memory =  PeriphAPB1       Memory      0x40000000  0x4001fFFF  W 
Memory =  PeriphAPB2       Memory      0x42000000  0x42007FFF  W
Memory =  PeriphAHB1       Memory      0x40020000  0x40107FFF  W 
Memory =  PeriphAHB2       Memory      0x48000000  0x4801FFFF  W
Memory =  PeriphAHB3       Memory      0x48020000  0x4803fFFF  W 
Memory =  PeriphAPB4       Memory      0x58000000  0x5800FFFF  W   
Memory =  PeriphAHB4       Memory      0x58020000  0x5802FFFF  W   
Memory =  PeriphAPB5       Memory      0x50000000  0x5000FFFF  W     
Memory =  PeriphAHB5       Memory      0x52000000  0x53FFFFFF  W  
Memory =  PeriphDebug      Memory      0x5C000000  0x5C01FFFF  W  
Memory =  ExtDev           Memory      0x60000000  0xDFFFFFFF  W   
Memory =  SystemSFR        Memory      0xE0000000  0xE00FFFFF  W   
Memory =  Flash 	   	   Memory      0x08000000  0x0800FFFF  R  
Memory =  RAM_AXI          Memory      0x24000000  0x24071FFF  RW 
Memory =  RAM_AHB          Memory      0x30003000  0x30007FFF  RW  
Memory =  RAM_AHB_Backup   Memory      0x38800000  0x38800FFF  RW 


TrustedRanges = true
UseSfrFilter = true

[SfrInclude]
File = STM32H7RSxx.svd
