                </enumeratedValues>
              </field>
              <field>
                <name>WDI</name>
                <description>Watchdog interrupt</description>
                <bitOffset>20</bitOffset>
                <bitWidth>1</bitWidth>
                <access>read-write</access>
                <enumeratedValues>
                  <enumeratedValue>
                    <name>B_0x0</name>
