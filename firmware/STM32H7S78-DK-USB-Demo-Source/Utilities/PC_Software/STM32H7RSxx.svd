        </register>
        <register>
          <name>IMR3</name>
          <displayName>IMR3</displayName>
          <description>EXTI CPU interrupt mask on direct event input</description>
          <addressOffset>0xA0</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x0F8BFFFF</resetValue>
          <fields>
            <field>
              <name>MR77</name>
              <description>Interrupt request from line x is masked</description>
