        </register>
        <register>
          <name>PR2</name>
          <displayName>PR2</displayName>
          <description>EXTI pending egister</description>
          <addressOffset>0x98</addressOffset>
          <size>0x20</size>
          <access>read-write</access>
          <resetValue>0x00000000</resetValue>
		  <resetMask>0xFFFFFFFF</resetMask>
          <fields>
            <field>
              <name>PR34</name>
              <description>configurable event inputs x pending bit</description>
              <bitOffset>2</bitOffset>
              <bitWidth>1</bitWidth>
            </field>
            <field>
              <name>PR46</name>
              <description>configurable event inputs x pending bit</description>
              <bitOffset>14</bitOffset>
